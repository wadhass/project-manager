PORT = 5000

MONGODB_URI=

JWT_SECRET='any secret string you want to use for JWT signing'

FRONTEND_URL = 'http://localhost:5173'

SENDGRID_API_KEY='your sendgrid api key'

FROM_EMAIL='your email address for sending emails'

# NODE_ENV is not set automatically, so tell Arcjet we're in dev
# You can leave this unset in prod
ARCJET_ENV='development'
# Get your site key from https://app.arcjet.com
ARCJET_KEY='your arcjet site key'